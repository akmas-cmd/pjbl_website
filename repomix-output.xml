        <form>
          <div class="input-group">
            <label for="email">Email atau Nomor Telepon</label>
            <input type="text" id="email" placeholder="Masukkan email atau nomor telepon">
          </div>

          <div class="input-group">
            <label for="password">Password</label>
            <input type="password" id="password" placeholder="Masukkan password">
          </div>

          <a href="#" class="forgot">Lupa Password?</a>

          <button type="button" class="btn-login" onclick="location.href='../patriotid_landingpage/landingpage.html'">Daftar</button>

          <div class="social-login">
            <button class="btn-google">Daftar Dengan Google</button>
            <button class="btn-facebook">Daftar Dengan Facebook</button>
          </div>

          <p class="register-link">
            Belum punya akun? <a href="../patriotid_daftar/daftar.html">Daftar</a>
          </p>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
</file>

