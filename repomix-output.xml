}

.dot.online {
  background: #27ae60;
  box-shadow: 0 0 0 2px #d4f5e2;
}

.dot.offline {
  background: #e74c3c;
  box-shadow: 0 0 0 2px #fde0dd;
}

.user-name {
  font-size: 13.5px;
  color: #333333;
}

.user-name strong {
  font-weight: 600;
  color: #111111;
}
