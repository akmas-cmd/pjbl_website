</head>
<body>

  <!-- Navbar -->
  <header class="navbar">
    <div class="logo">
      <img src="../logo.png" alt="Logo PatriotID">
      <h1>Patriot<span>ID</span></h1>
    </div>
    <nav>
      <ul>
        <li><a href="../patriotid_landingpage/landingpage.html#beranda">Beranda</a></li>
        <li><a href="../patriotid_landingpage/landingpage.html#profil">Pahlawan</a></li>
