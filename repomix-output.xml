<file path="includes/koneksi.php">
<?php
// ============================================================
//  PATRIOTID — Koneksi Database
//  File ini di-include di semua halaman yang butuh database.
//  Letakkan file ini di folder: patriotid/includes/koneksi.php
// ============================================================

$host   = 'localhost';
$dbname = 'patriotid_db';
$user   = 'root';
$pass   = '';           // Kosong = default XAMPP, ganti jika kamu set password

try {
    $pdo = new PDO("mysql:host=$host;dbname=$dbname;charset=utf8mb4", $user, $pass);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);
    $pdo->setAttribute(PDO::ATTR_DEFAULT_FETCH_MODE, PDO::FETCH_ASSOC);
} catch (PDOException $e) {
    die("<p style='color:red;font-family:sans-serif;padding:20px'>
        <strong>Koneksi database gagal!</strong><br>
        Pastikan XAMPP sudah aktif dan database <em>patriotid_db</em> sudah dibuat.<br><br>
        Error: " . $e->getMessage() . "
    </p>");
}
</file>

<file path="patriotid_daftar/daftar.css">
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  font-family: "Poppins", sans-serif;
}

body {
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
  min-height: 100vh;
}

.container {
  display: flex;
  width: 90%;
  max-width: 1100px;
  height: 600px;
  border-radius: 20px;
  overflow: hidden;
  box-shadow: 0 4px 20px rgba(0,0,0,0.1);
}

/* ===== Bagian kiri ===== */
.left-section {
  flex: 1;
  background: linear-gradient(180deg, #800000, #400000);
  display: flex;
  justify-content: center;
  align-items: center;
  position: relative;
}

.garuda {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.9;
}

/* ===== Bagian kanan ===== */
.right-section {
  flex: 1;
  background-color: #fff;
  display: flex;
  justify-content: center;
  align-items: center;
}

.form-box {
  width: 80%;
  max-width: 400px;
  text-align: center;
}

.logo {
  width: 80px;
  margin-bottom: 10px;
}

h2 {
  font-size: 28px;
  color: #000;
}

p {
  color: #555;
  margin-bottom: 20px;
}

/* ===== Input ===== */
.input-group {
  text-align: left;
  margin-bottom: 15px;
}

.input-group label {
  font-weight: 500;
  font-size: 14px;
  color: #333;
}

.input-group input {
  width: 100%;
  padding: 10px;
  border: 1px solid #ddd;
  border-radius: 8px;
  margin-top: 5px;
}

.forgot {
  display: block;
  text-align: right;
  font-size: 13px;
  color: #a00000;
  text-decoration: none;
  margin-bottom: 10px;
}

.forgot:hover {
  text-decoration: underline;
}

/* ===== Tombol login ===== */
.btn-login {
  background-color: #800000;
  color: #fff;
  width: 100%;
  padding: 12px;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-size: 16px;
  font-weight: 600;
  margin-top: 10px;
}

.btn-login:hover {
  background-color: #a00000;
}

/* ===== Login sosial ===== */
.social-login {
  display: flex;
  gap: 10px;
  margin-top: 15px;
}

.btn-google, .btn-facebook {
  flex: 1;
  padding: 10px;
  border: 1px solid #ccc;
  border-radius: 8px;
  background-color: #fff;
  cursor: pointer;
  font-size: 14px;
}

.btn-google:hover, .btn-facebook:hover {
  background-color: #f5f5f5;
}

/* ===== Link daftar ===== */
.register-link {
  margin-top: 15px;
  font-size: 14px;
}

.register-link a {
  color: #a00000;
  text-decoration: none;
  font-weight: 600;
}

.register-link a:hover {
  text-decoration: underline;
}

/* ===== Responsif ===== */
@media (max-width: 900px) {
  .container {
    flex-direction: column;
    height: auto;
  }

  .left-section {
    height: 250px;
  }

  .garuda {
    width: 40%;
  }
}
</file>

<file path="patriotid_daftar/daftar.html">
