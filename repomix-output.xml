}

.nav-item.active {
  color: #8B1010;
  font-weight: 600;
  border-left-color: #8B1010;
  background: #fdf0f0;
}

/* ── MAIN CONTENT ── */
.main {
  flex: 1;
  padding: 32px 36px;
}

.page-title {
  font-size: 20px;
  font-weight: 600;
  color: #222222;
  margin-bottom: 24px;
}

.section-title {
  font-size: 16px;
  font-weight: 600;
  color: #8B1010;
  margin-bottom: 16px;
}

/* ── STAT CARDS ── */
.cards-row {
  display: grid;
  grid-template-columns: 1fr 1fr 1.8fr;
  gap: 16px;
  margin-bottom: 28px;
}

.stat-card {
  background: #ffffff;
  border: 1px solid #e8e8e8;
  border-radius: 10px;
  padding: 18px 22px;
}

.stat-label {
  font-size: 12px;
  color: #888888;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.stat-value {
  font-size: 28px;
  font-weight: 700;
  color: #222222;
}

.quote-card {
  background: #8B1010;
  border-radius: 10px;
  padding: 18px 22px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.quote-text {
  font-size: 15px;
  font-weight: 600;
  color: #ffffff;
  margin-bottom: 6px;
}

.quote-sub {
  font-size: 12px;
  color: #e8b0b0;
}

/* ── ONLINE USERS ── */
.online-card {
  background: #ffffff;
  border: 1px solid #e8e8e8;
  border-radius: 10px;
  overflow: hidden;
}

.online-header {
  background: #8B1010;
  padding: 11px 18px;
}

.online-header-text {
  font-size: 13px;
  font-weight: 600;
  color: #ffffff;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 13px 18px;
  border-bottom: 1px solid #f2f2f2;
  transition: background 0.12s;
}

.user-row:last-child {
  border-bottom: none;
}

.user-row:hover {
  background: #fafafa;
}

.dot {
  width: 11px;
  height: 11px;
  border-radius: 50%;
  flex-shrink: 0;
}

.dot.online {
  background: #27ae60;
  box-shadow: 0 0 0 2px #d4f5e2;
}

.dot.offline {
  background: #e74c3c;
  box-shadow: 0 0 0 2px #fde0dd;
}

.user-name {
  font-size: 13.5px;
  color: #333333;
}

.user-name strong {
  font-weight: 600;
  color: #111111;
}

