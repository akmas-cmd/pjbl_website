        #sidebar-wrapper {
            min-height: 100vh;
            width: var(--sidebar-width);
            background-color: var(--putih);
            border-right: 4px solid var(--merah-indo);
            transition: transform 0.3s ease;
            position: fixed;
            z-index: 1000;
            box-shadow: 2px 0 10px rgba(0, 0, 0, 0.05);
            top: 0;
            left: 0;
        }

        #sidebar-wrapper .sidebar-heading {
            padding: 1.5rem;
            font-size: 1.4rem;
            color: var(--merah-indo);
            border-bottom: 1px solid rgba(0, 0, 0, 0.1);
            font-weight: bold;
        }

        .list-group-item-sidebar {
            background-color: transparent;
            color: var(--teks-utama);
            border: none;
            padding: 1rem 1.5rem;
            transition: all 0.2s;
            cursor: pointer;
            display: block;
            text-decoration: none;
        }

        .list-group-item-sidebar:hover {
            background-color: var(--merah-muda);
            color: var(--merah-indo);
            padding-left: 1.8rem;
        }

        .list-group-item-sidebar.active {
            background-color: var(--merah-muda);
            color: var(--merah-indo);
            font-weight: 600;
            border-left: 5px solid var(--merah-indo);
        }

        /* CONTENT */
        #page-content-wrapper {
            margin-left: var(--sidebar-width);
            width: calc(100% - var(--sidebar-width));
            transition: margin 0.3s ease;
            min-height: 100vh;
        }

        /* NAVBAR */
        .top-navbar {
            background: white;
            border-bottom: 2px solid var(--merah-indo);
            padding: 1rem 1.5rem;
            position: sticky;
            top: 0;
            z-index: 999;
            box-shadow: 0 2px 5px rgba(0,0,0,0.05);
        }

        /* CARDS */
        .card-stat {
            border-left: 4px solid var(--merah-indo);
            transition: transform 0.2s;
        }

        .card-stat:hover {
            transform: translateY(-5px);
        }

        .btn-merah {
            background-color: var(--merah-indo);
            color: white;
